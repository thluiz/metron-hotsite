---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Metron Showrunners">

  <div class="metron-composition">
    <img src="/images/metron-logo.png" alt="Metron Showrunners" class="metron-mark" />
    <span class="metron-bar"></span>
  </div>

  <div class="ip-stage">
    <img src="/images/hybris-logo.png" alt="Hybris" class="ip-logo" data-slide="1" />
    <img src="/images/laya-logo.png" alt="Laya" class="ip-logo" data-slide="2" />
    <img src="/images/intersessoes-logo.png" alt="Intersessões" class="ip-logo" data-slide="3" />
  </div>

  <section id="cover" class="slide"></section>
  <section id="slide-hybris" class="slide"></section>
  <section id="slide-laya" class="slide"></section>
  <section id="slide-intersessoes" class="slide"></section>

</Layout>

<style>
  .metron-composition {
    position: fixed;
    top: 22vh;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    pointer-events: none;
  }
  .metron-mark {
    width: clamp(142px, 18.14vw, 272px);
    height: auto;
    display: block;
    align-self: center;
  }
  .metron-bar {
    width: 1px;
    height: clamp(220px, 42vh, 480px);
    background: rgba(216, 216, 224, 0.55);
  }

  .ip-stage {
    position: fixed;
    left: calc(50% + (clamp(142px, 18.14vw, 272px) + 1.5rem) / 2);
    bottom: 8vh;
    transform: translateX(-50%);
    width: clamp(220px, 28vw, 420px);
    height: clamp(100px, 14vw, 200px);
    z-index: 10;
    pointer-events: none;
  }
  .ip-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .ip-logo.active {
    opacity: 1;
  }

  :global(#cover),
  :global(#slide-hybris),
  :global(#slide-laya),
  :global(#slide-intersessoes) {
    background-attachment: fixed;
    box-shadow: none;
  }
</style>

<script>
  const slides = document.querySelectorAll('.slide');
  const ipLogos = document.querySelectorAll('.ip-logo');

  const tick = () => {
    const vh = window.innerHeight;
    const vcenter = vh / 2;
    let bestIdx = -1;
    let bestDist = Infinity;
    slides.forEach((slide, i) => {
      const rect = (slide as HTMLElement).getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      const dist = Math.abs(center - vcenter);
      if (dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    });
    ipLogos.forEach((logo, i) => {
      logo.classList.toggle('active', i === bestIdx - 1);
    });
  };

  window.addEventListener('scroll', tick, { passive: true });
  window.addEventListener('resize', tick);
  tick();
</script>
