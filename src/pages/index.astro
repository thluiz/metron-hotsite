---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Metron Showrunners">

  <section id="cover" class="slide flex flex-col items-center justify-center">

    <div class="metron-mark">
      <span class="metron-word">METRON</span>
      <span class="metron-sep"></span>
      <span class="metron-sub">SHOWRUNNERS</span>
    </div>

    <p class="cover-credit">
      Exclusive Owner of the
      <span class="hybris-inline">HYBRI<em>s</em></span>
      Franchise Intellectual Property
    </p>

  </section>

</Layout>

<style>
  .metron-mark {
    display: grid;
    grid-template-columns: auto 1px auto;
    align-items: center;
    column-gap: 0.85rem;
    color: #d8d8e0;
    letter-spacing: 0.04em;
  }
  .metron-word {
    font-family: 'Cinzel', serif;
    font-weight: 500;
    font-size: clamp(1.4rem, 2.6vw, 2.2rem);
    letter-spacing: 0.08em;
  }
  .metron-sep {
    align-self: stretch;
    background: rgba(216, 216, 224, 0.55);
    width: 1px;
  }
  .metron-sub {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: clamp(0.6rem, 0.9vw, 0.75rem);
    letter-spacing: 0.32em;
    align-self: end;
    padding-bottom: 2px;
  }

  .cover-credit {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Cinzel', serif;
    font-size: clamp(0.75rem, 1vw, 0.9rem);
    letter-spacing: 0.06em;
    color: rgba(232, 232, 239, 0.85);
    white-space: nowrap;
  }
  .hybris-inline {
    margin: 0 0.25em;
    letter-spacing: 0.08em;
  }
  .hybris-inline em {
    font-style: italic;
    letter-spacing: 0;
  }
</style>
