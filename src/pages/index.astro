---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Metron Showrunners">

  <div class="metron-composition">
    <img src="/images/metron-logo.png" alt="Metron Showrunners" class="metron-mark" />
    <span class="metron-bar"></span>
  </div>

  <section id="cover" class="slide"></section>
  <section id="cover-end" class="slide"></section>

</Layout>

<style>
  .metron-composition {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) translateX(-3rem);
    z-index: 10;
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    pointer-events: none;
  }
  .metron-mark {
    width: clamp(142px, 18.14vw, 272px);
    height: auto;
    display: block;
  }
  .metron-bar {
    position: relative;
    align-self: stretch;
    width: 1px;
    background: rgba(216, 216, 224, 0.55);
  }
  .metron-bar::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    width: 1px;
    height: var(--bar-rise, 0px);
    background: rgba(216, 216, 224, 0.55);
  }
  .metron-bar::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 1px;
    height: 50vh;
    background: rgba(216, 216, 224, 0.55);
  }

  :global(#cover),
  :global(#cover-end) {
    background-attachment: fixed;
    box-shadow: none;
  }
</style>

<script>
  const setBarRise = () => {
    const scrollY = window.scrollY;
    const vh = window.innerHeight;
    const max = vh * 0.55;
    const progress = Math.min(1, scrollY / vh);
    document.documentElement.style.setProperty('--bar-rise', `${progress * max}px`);
  };
  window.addEventListener('scroll', setBarRise, { passive: true });
  window.addEventListener('resize', setBarRise);
  setBarRise();
</script>
