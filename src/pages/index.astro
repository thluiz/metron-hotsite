---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Metron Showrunners">

  <div class="composition">
    <img src="/images/metron-logo.png" alt="Metron Showrunners" class="metron-mark" />
    <span class="metron-bar"></span>
    <div class="ip-stage">
      <img src="/images/hybris-logo.png" alt="Hybris" class="ip-logo" />
      <img src="/images/laya-logo.png" alt="Laya" class="ip-logo" />
      <img src="/images/intersessoes-logo.png" alt="Intersessões" class="ip-logo" />
    </div>
  </div>

  <section id="slide-hybris" class="slide"></section>
  <section id="slide-laya" class="slide"></section>
  <section id="slide-intersessoes" class="slide"></section>

  <nav id="nav-dots" aria-label="IP navigation">
    <a href="#slide-hybris" aria-label="Hybris"></a>
    <a href="#slide-laya" aria-label="Laya"></a>
    <a href="#slide-intersessoes" aria-label="Intersessões"></a>
  </nav>

</Layout>

<style>
  .composition {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    pointer-events: none;
  }
  .metron-mark {
    width: clamp(142px, 18.14vw, 272px);
    height: auto;
    display: block;
  }
  .metron-bar {
    width: 1px;
    height: clamp(80px, 11vw, 160px);
    background: rgba(216, 216, 224, 0.55);
  }

  .ip-stage {
    position: relative;
    width: clamp(160px, 20vw, 300px);
    height: clamp(80px, 11vw, 160px);
  }
  .ip-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .ip-logo.active {
    opacity: 1;
  }
</style>

<script>
  const slides = document.querySelectorAll('.slide');
  const ipLogos = document.querySelectorAll('.ip-logo');

  const tick = () => {
    const vh = window.innerHeight;
    const vcenter = vh / 2;
    let bestIdx = 0;
    let bestDist = Infinity;
    slides.forEach((slide, i) => {
      const rect = (slide as HTMLElement).getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      const dist = Math.abs(center - vcenter);
      if (dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    });
    ipLogos.forEach((logo, i) => {
      logo.classList.toggle('active', i === bestIdx);
    });
  };

  window.addEventListener('scroll', tick, { passive: true });
  window.addEventListener('resize', tick);
  tick();
</script>
