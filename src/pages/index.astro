---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---
<Layout title="Metron Showrunners">

  <div class="composition">
    <img src="/images/metron-logo.png?v=1" alt="Metron Showrunners" class="metron-mark" />
    <div class="ip-stage">
      <img src="/images/hybris-logo.png?v=1" alt="Hybris" class="ip-logo ip-logo--hybris" />
      <img src="/images/laya-logo.png?v=1" alt="Laya" class="ip-logo" />
      <img src="/images/intersessoes-logo.png?v=1" alt="Intersessões" class="ip-logo" />
    </div>
  </div>

  <section id="slide-hybris" class="slide"></section>
  <section id="slide-laya" class="slide"></section>
  <section id="slide-intersessoes" class="slide"></section>

  <nav id="nav-dots" aria-label="IP navigation">
    <a href="#slide-hybris" aria-label="Hybris"></a>
    <a href="#slide-laya" aria-label="Laya"></a>
    <a href="#slide-intersessoes" aria-label="Intersessões"></a>
  </nav>

</Layout>

<style>
  .composition {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    pointer-events: none;
  }
  .metron-mark {
    width: clamp(108px, 18.14vw, 272px);
    height: auto;
    display: block;
  }

  .ip-stage {
    position: relative;
    width: clamp(122px, 20vw, 300px);
    height: clamp(62px, 11vw, 160px);
  }
  .ip-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .ip-logo.active {
    opacity: 1;
  }
  .ip-logo--hybris {
    transform: scale(1.35);
    transform-origin: left center;
  }

  @media (max-width: 640px) {
    .composition {
      /* Composition becomes a transparent anchor: items are positioned
         absolutely relative to viewport center, guaranteeing they share
         the same horizontal baseline regardless of size. */
      top: 50%;
      left: 0;
      right: 0;
      transform: translateY(-50%);
      display: block;
    }
    .metron-mark {
      position: absolute;
      right: calc(50% + 4px);
      top: 0;
      transform: translateY(-50%);
      width: clamp(135px, 38vw, 272px);
    }
    .ip-stage {
      position: absolute;
      left: calc(50% + 12px);
      top: 0;
      transform: translateY(-50%);
      width: clamp(145px, 42vw, 260px);
      height: auto;
      aspect-ratio: 1.7 / 1;
    }
    .ip-logo {
      object-position: left center;
    }
    .ip-logo--hybris {
      transform: scale(1.35);
      transform-origin: left center;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll('.slide');
  const ipLogos = document.querySelectorAll('.ip-logo');
  let currentIdx = 0;

  const tick = () => {
    const vh = window.innerHeight;
    const vcenter = vh / 2;
    let bestIdx = 0;
    let bestDist = Infinity;
    slides.forEach((slide, i) => {
      const rect = (slide as HTMLElement).getBoundingClientRect();
      const center = rect.top + rect.height / 2;
      const dist = Math.abs(center - vcenter);
      if (dist < bestDist) {
        bestDist = dist;
        bestIdx = i;
      }
    });
    currentIdx = bestIdx;
    ipLogos.forEach((logo, i) => {
      logo.classList.toggle('active', i === bestIdx);
    });
  };

  let navLock = false;
  const navigate = (dir: number) => {
    if (navLock) return;
    const n = slides.length;
    const target = ((currentIdx + dir) % n + n) % n;
    navLock = true;
    setTimeout(() => { navLock = false; }, 650);
    (slides[target] as HTMLElement).scrollIntoView({ behavior: 'smooth' });
  };

  // Horizontal wheel / trackpad → slide navigation
  window.addEventListener('wheel', (e) => {
    if (Math.abs(e.deltaX) > Math.abs(e.deltaY) && Math.abs(e.deltaX) > 10) {
      e.preventDefault();
      navigate(e.deltaX > 0 ? 1 : -1);
    }
  }, { passive: false });

  // Keyboard shortcuts
  window.addEventListener('keydown', (e) => {
    const t = e.target as HTMLElement | null;
    if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
    if (e.code === 'Space' || e.key === 'ArrowRight' || e.key === 'ArrowDown') {
      e.preventDefault();
      navigate(1);
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
      e.preventDefault();
      navigate(-1);
    }
  });

  window.addEventListener('scroll', tick, { passive: true });
  window.addEventListener('resize', tick);
  tick();
</script>
