---
interface Props {
  title?: string;
}
const { title = 'Metron' } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Metron" />
    <meta name="theme-color" content="#b09060" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Cinzel and Cinzel Decorative are self-hosted from /public/fonts/
         (loaded via @font-face in global.css). Other families come from
         Google Fonts as fallback for legacy components. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <link rel="preload" href="/fonts/Cinzel-Regular.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/Cinzel-Bold.otf" as="font" type="font/otf" crossorigin />
  </head>
  <body>
    <slot />

    <script>
      // Reveal elements when their parent slide is 50%+ visible
      const slideObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.querySelectorAll('.rv').forEach((el) => {
                el.classList.add('visible');
              });
            }
          });
        },
        { threshold: 0.45 }
      );
      document.querySelectorAll('.slide').forEach((s) => slideObs.observe(s));

      // Scroll-driven crossfade: each slide's content fades based on how
      // centered the slide is within the viewport. Slides off-screen sit
      // at opacity 0; the centered slide at 1; transitioning slides cross-
      // fade smoothly through the middle.
      const fadeSlides = document.querySelectorAll('.slide');
      const updateFades = () => {
        const vh = window.innerHeight;
        const vcenter = vh / 2;
        fadeSlides.forEach((slide) => {
          const rect = slide.getBoundingClientRect();
          const center = rect.top + rect.height / 2;
          // distance: 0 = perfectly centered, 1 = one viewport away
          const distance = Math.abs(center - vcenter) / vh;
          // Stay fully visible while within ~25% of center, then ramp down
          const op = Math.max(0, Math.min(1, 1 - (distance - 0.25) * 2.5));
          (slide as HTMLElement).style.setProperty('--content-opacity', String(op));
        });
      };
      let scheduled = false;
      window.addEventListener('scroll', () => {
        if (!scheduled) {
          scheduled = true;
          requestAnimationFrame(() => { updateFades(); scheduled = false; });
        }
      }, { passive: true });
      window.addEventListener('resize', updateFades);
      updateFades();

      // Nav dot active state
      const dots = document.querySelectorAll('#nav-dots a');
      const slides = document.querySelectorAll('.slide');
      const dotObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const idx = Array.from(slides).indexOf(entry.target as Element);
            if (entry.isIntersecting && idx >= 0 && dots[idx]) {
              dots.forEach((d) => d.classList.remove('active'));
              dots[idx].classList.add('active');
            }
          });
        },
        { threshold: 0.6 }
      );
      slides.forEach((s) => dotObs.observe(s));
    </script>
  </body>
</html>
