---
// White lightning crack SVG — replicates the vertical bolt from the PDF
// Position: absolute, full height, centered horizontally
---
<div class="lightning absolute inset-0 pointer-events-none flex justify-center" aria-hidden="true">
  <svg
    viewBox="0 0 120 800"
    preserveAspectRatio="none"
    class="h-full w-auto opacity-80"
    xmlns="http://www.w3.org/2000/svg"
  >
    <!-- Main trunk -->
    <polyline
      points="60,0 57,55 63,62 55,140 64,148 57,240 65,250 56,360 66,372 57,480 65,492 58,590 66,604 60,800"
      stroke="rgba(255,255,255,0.88)"
      stroke-width="1.2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <!-- Left branch mid -->
    <polyline
      points="55,140 40,190 30,240 18,310"
      stroke="rgba(255,255,255,0.55)"
      stroke-width="0.7"
      fill="none"
      stroke-linecap="round"
    />
    <!-- Right branch mid -->
    <polyline
      points="65,250 82,310 92,380 100,460"
      stroke="rgba(255,255,255,0.5)"
      stroke-width="0.65"
      fill="none"
      stroke-linecap="round"
    />
    <!-- Small left branch upper -->
    <polyline
      points="57,55 45,90 38,115"
      stroke="rgba(255,255,255,0.35)"
      stroke-width="0.45"
      fill="none"
      stroke-linecap="round"
    />
    <!-- Small right branch lower -->
    <polyline
      points="57,480 72,530 80,570"
      stroke="rgba(255,255,255,0.4)"
      stroke-width="0.5"
      fill="none"
      stroke-linecap="round"
    />
  </svg>
</div>
